# ── boomtime configuration ───────────────────────────────────────────────────
# NOTE: keep values free of inline "# comments" — godotenv treats the rest of the
# line as the value. Put comments on their own lines.

# Server
BOOM_PORT=8080
# dev = text logs; prod / production = JSON logs.
# gaka-6jm.9: when BOOM_ENV=prod (or production), boomtime REFUSES to start
# unless BOOM_ENCRYPTION_KEY is set + valid. In dev/test the missing-key path
# is a WARN only so local flows keep working.
BOOM_ENV=dev
# debug | info | warn | error
BOOM_LOG_LEVEL=info
BOOM_HTTP_LOG=true
# set if behind a reverse-proxy subpath
BOOM_API_PREFIX=
# toggle off after creating your account
BOOM_ENABLE_REGISTRATION=true
# browser session expiry (hours)
BOOM_SESSION_EXPIRY=24
# empty = serve the SPA embedded in the binary
BOOM_DASHBOARD_PATH=
BOOM_BADGE_URL=http://localhost:8080
BOOM_SHIELDS_IO_URL=https://img.shields.io

# ── refresh_token cookie Secure flag (gaka-b5x.1) ─────────────────────────────
# When set, forces the Secure attribute on the refresh_token cookie on / off
# regardless of BOOM_ENV. Defaults to TRUE when BOOM_ENV=prod|production and
# FALSE in dev (so browsers accept the cookie on http://localhost). Set to
# 1/true if you serve dev over a local HTTPS reverse proxy and want to
# smoke-test the prod cookie shape.
# BOOM_COOKIE_SECURE=

# ── CORS allowlist (gaka-n5r) ─────────────────────────────────────────────────
# Comma-separated exact-match Origin allowlist. Each entry MUST be
# scheme://host[:port] with no trailing slash / path / query.
# Match is case-sensitive on scheme+host+port — attacker origins are denied
# outright, and the response omits Access-Control-Allow-Origin entirely.
# In dev, leaving this empty falls back to http://localhost:5173 +
# http://localhost:8080 with a WARN log. In prod (BOOM_ENV=prod|production)
# an empty value is a HARD FAILURE at startup.
BOOM_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ── Rate limiting (gaka-jk6 / gaka-ddp / gaka-awh.1) ──────────────────────────
# Universal token-bucket per (endpoint-group + client-identity). Buckets are
# in-memory (single-instance) — a redis-backed variant is tracked as a
# follow-up bead. Defaults:
#   auth-write     : 10 requests / minute / IP   → /auth/login, /auth/register,
#                                                  /auth/refresh_token,
#                                                  POST /api/v1/users/current/password
#   wakatime-probe : 5  requests / minute / user → POST /api/v1/users/current/wakatime_key
#   default        : 60 requests / second / IP   → everything else
# GET /healthz and OPTIONS * always bypass. On 429 the response includes
# `Retry-After` (seconds) and body {"error":"rate limited","retryAfter":N}.
#
# Testing hook: set to "1" to disable the middleware entirely (existing
# integration tests hammer endpoints without hitting the limit). Emits a
# WARN log on startup when active. DO NOT set this in production.
BOOM_DISABLE_RATE_LIMIT=
# Per-group overrides. Rate is tokens PER SECOND (float, e.g. 0.1666 = 10/min);
# Burst is the max in-flight burst (int). Invalid values fall back to defaults
# with a WARN.
#   BOOM_RATELIMIT_AUTH_WRITE_RATE=0.1666
#   BOOM_RATELIMIT_AUTH_WRITE_BURST=10
#   BOOM_RATELIMIT_WAKATIME_PROBE_RATE=0.0833
#   BOOM_RATELIMIT_WAKATIME_PROBE_BURST=5
#   BOOM_RATELIMIT_DEFAULT_RATE=60
#   BOOM_RATELIMIT_DEFAULT_BURST=60

# Performance tuning for the heavy stats aggregations
# work_mem applied (transaction-scoped) to stats/timeline/leaderboards queries so
# large sorts stay in RAM instead of spilling to disk. 256MB is plenty at ~500k
# rows; 512MB buys ~6% more. Format: <int>(kB|MB|GB).
BOOM_STATS_WORK_MEM=256MB
# TTL (seconds) for cached aggregation payloads; 0 disables caching.
BOOM_STATS_CACHE_TTL=30

# Database (matches docker-compose.yml)
BOOM_DB_HOST=localhost
BOOM_DB_PORT=5432
BOOM_DB_NAME=test
BOOM_DB_USER=test
BOOM_DB_PASS=test

# ── Wakatime interop (self-hosting to avoid wakatime.com subscription) ────────
# Token used to IMPORT your history from wakatime.com and/or forward heartbeats.
# Get it from https://wakatime.com/settings/account (Secret API Key).
WAKATIME_API_KEY=

# Optional: forward every incoming heartbeat to another Wakatime-compatible server.
BOOM_REMOTE_WRITE_URL=
BOOM_REMOTE_WRITE_TOKEN=${WAKATIME_API_KEY}

# Optional: GitHub token to attribute time-spent to commits.
GITHUB_TOKEN=

# ── Encryption-at-rest key (gaka-6jm.2) ───────────────────────────────────────
# Base64-encoded 32-byte (256-bit) symmetric key used to encrypt user-scoped
# secrets stored in the DB (currently: the imported Wakatime API key per user).
# Generate with: openssl rand -base64 32
# If unset and BOOM_ENV=dev/test, boomtime boots with a WARNING log; the
# encrypted-at-rest features stay inert until you configure one. If unset
# and BOOM_ENV=prod/production, boomtime EXITS at startup (gaka-6jm.9).
# Rotating this value after keys are saved needs `boomtime
# rotate-encryption-key --old <b64> --new <b64>` (gaka-6jm.7) BEFORE flipping
# the env; a hot swap would strand every existing ciphertext.
BOOM_ENCRYPTION_KEY=
