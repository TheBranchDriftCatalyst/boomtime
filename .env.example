# ── boomtime configuration ───────────────────────────────────────────────────
# NOTE: keep values free of inline "# comments" — godotenv treats the rest of the
# line as the value. Put comments on their own lines.

# Server
BOOM_PORT=8080
# dev = text logs; prod = JSON logs
BOOM_ENV=dev
# debug | info | warn | error
BOOM_LOG_LEVEL=info
BOOM_HTTP_LOG=true
# set if behind a reverse-proxy subpath
BOOM_API_PREFIX=
# toggle off after creating your account
BOOM_ENABLE_REGISTRATION=true
# browser session expiry (hours)
BOOM_SESSION_EXPIRY=24
# empty = serve the SPA embedded in the binary
BOOM_DASHBOARD_PATH=
BOOM_BADGE_URL=http://localhost:8080
BOOM_SHIELDS_IO_URL=https://img.shields.io

# Performance tuning for the heavy stats aggregations
# work_mem applied (transaction-scoped) to stats/timeline/leaderboards queries so
# large sorts stay in RAM instead of spilling to disk. 256MB is plenty at ~500k
# rows; 512MB buys ~6% more. Format: <int>(kB|MB|GB).
BOOM_STATS_WORK_MEM=256MB
# TTL (seconds) for cached aggregation payloads; 0 disables caching.
BOOM_STATS_CACHE_TTL=30

# Database (matches docker-compose.yml)
BOOM_DB_HOST=localhost
BOOM_DB_PORT=5432
BOOM_DB_NAME=test
BOOM_DB_USER=test
BOOM_DB_PASS=test

# ── Wakatime interop (self-hosting to avoid wakatime.com subscription) ────────
# Token used to IMPORT your history from wakatime.com and/or forward heartbeats.
# Get it from https://wakatime.com/settings/account (Secret API Key).
WAKATIME_API_KEY=

# Optional: forward every incoming heartbeat to another Wakatime-compatible server.
BOOM_REMOTE_WRITE_URL=
BOOM_REMOTE_WRITE_TOKEN=${WAKATIME_API_KEY}

# Optional: GitHub token to attribute time-spent to commits.
GITHUB_TOKEN=
